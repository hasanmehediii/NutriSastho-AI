# Backend local/deployment environment.
TYPE=remote
ENV=production

# Deployment should use Neon via DATABASE_URL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Optional local Docker fallback.
DATABASE_URL_LOCAL=postgresql://tester:secret@localhost:7432/bugtracker
DB_USER=tester
DB_PASSWORD=secret
DB_NAME=bugtracker
DOCKER_VOLUME_PATH=./docker_data

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

HOST=0.0.0.0
PORT=8000
RELOAD=false
CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.vercel.app
FRONTEND_URL=https://your-frontend-domain.vercel.app

GEMINI_API_KEY=
GEMINI_API_SECRET=
GROQ_API_KEY=
MCP_SERVER_PORT=7860

# Data retention, in days. Cleanup keeps each user's latest row by default.
RETENTION_EXERCISE_PLANS_DAYS=30
RETENTION_BUDGET_PLANS_DAYS=180
RETENTION_HEALTH_PROFILES_DAYS=365
