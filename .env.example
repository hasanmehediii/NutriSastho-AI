# Shared deployment environment. Copy values into your hosting provider.
TYPE=remote
ENV=production

# Neon/Postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Backend auth
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

# Service binding
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=https://your-frontend-domain.vercel.app
FRONTEND_URL=https://your-frontend-domain.vercel.app
BACKEND_URL=https://your-backend-domain.example.com
MCP_SERVER_URL=https://your-mcp-domain.example.com

# AI providers
GEMINI_API_KEY=
GEMINI_API_SECRET=
GROQ_API_KEY=
HUGGINGFACE_API_KEY=

# Data retention, in days. Cleanup keeps each user's latest row by default.
RETENTION_EXERCISE_PLANS_DAYS=30
RETENTION_BUDGET_PLANS_DAYS=180
RETENTION_HEALTH_PROFILES_DAYS=365
