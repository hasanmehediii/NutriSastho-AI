# Frontend server-side API routes call the backend and MCP server.
BACKEND_URL=https://your-backend-domain.example.com
NEXT_PUBLIC_BACKEND_URL=https://your-backend-domain.example.com
MCP_SERVER_URL=https://your-mcp-domain.example.com

# Required in production for encrypted session cookies.
AUTH_COOKIE_SECRET=replace-with-a-long-random-secret

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
